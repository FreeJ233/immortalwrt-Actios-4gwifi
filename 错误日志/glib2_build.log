	d=${d#man/}; \
	dst=${d##*/}; \
	for m in `gawk \
		'/^\.S[h|H] NAME/ {ok=1; next} ok {print; exit}' $d \
		| /mnt/openwrt/staging_dir/host/bin/sed \
